{
    "manifest_version": 2,
    "name": "SciHelper",
    "version": "2.1",
    "description": "Scientific writing helper for Google Docs and web forms.",

    "permissions": [
        "tabs",
        "storage",
        "<all_urls>"
    ],

    "web_accessible_resources": [
        "SciHelper.js",
        "SciHelper_lib.js",
        "resources.js",
        "Chemistry_lib.js",
        "General_lib.js",
        "Physics_lib.js",
        "katex/fonts/*",

        "style_chem.css",
        "style_phys.css",
        "style_gen.css",
        "style.css"
    ],

    "browser_specific_settings": {
        "gecko": {
            "id": "scihelper@yourdomain.com"
        }
    },

    "options_ui": {
            "page": "./optionPage/options.html",
            "open_in_tab": false
    },

    "background": {
        "scripts": ["background.js"],
        "persistent": false
    },

    "icons": {
        "128": "icon.png"
    },
    "browser_action": {
        "default_icon": "icon.png"
    }
}