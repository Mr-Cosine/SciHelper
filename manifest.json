{
    "manifest_version": 3,
    "name": "SciHelper",
    "version": "1.0",
    "description": "Scientific writing helper for Google Docs and web forms.",

    "permissions": [
        "scripting",
        "activeTab"
    ],
    "host_permissions": [
        "https://docs.google.com/*",
        "https://*.google.com/*",
        "https://www.onlinenotepad.io/*"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://docs.google.com/document/*",
                "https://www.onlinenotepad.io/*"
            ],
            "css": [
                "style.css",
                "style_chem.css",
                "style_phys.css",
                "style_gen.css",
                "katex/katex.min.css"
            ],
            "js": [
                "katex/katex.min.js",
                "SciHelper_lib.js",
                "Chemistry_lib.js", 
                "General_lib.js",
                "Physics_lib.js",
                "resources.js",
                "SciHelper.js"
            ],
            "run_at": "document_end"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "SciHelper.js",
                "SciHelper_lib.js",
                "resources.js",
                "Chemistry_lib.js",
                "General_lib.js",
                "Physics_lib.js",
                "katex/fonts/*"
            ],
            "matches": ["https://docs.google.com/document/*"]
        }
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "scihelper@yourdomain.com"
        }
    },
    "icons": {
        "128": "icon.png"
    },
    "action": {
        "default_icon": "icon.png"
    }
}